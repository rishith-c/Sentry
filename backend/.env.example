# Copy to backend/.env and fill in real values

# NASA FIRMS fire hotspot API key
FIRMS_MAP_KEY=your_firms_map_key_here

# USGS earthquake feed (default points to all_hour feed)
USGS_FEED_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson

# Palantir Foundry integration
PALANTIR_HOST=your_palantir_host_here
PALANTIR_TOKEN=your_palantir_token_here

# ElevenLabs TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Hugging Face media triage
HF_TOKEN=your_huggingface_token_here
HF_ASR_MODEL=openai/whisper-large-v3
HF_ZERO_SHOT_MODEL=facebook/bart-large-mnli
HF_IMAGE_CAPTION_MODEL=Salesforce/blip-image-captioning-base

# Runtime environment (development | production)
ENV=development

# SQLite database path
DB_PATH=sentinel.db

# Comma-separated list of allowed CORS origins
# In production: set to your Vercel frontend URL
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173
