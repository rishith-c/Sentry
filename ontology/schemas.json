{
  "object_types": {
    "ComputeNode": {
      "primary_key": "node_id",
      "properties": {
        "node_id": { "type": "string" },
        "hostname": { "type": "string" },
        "ip_address": { "type": "string" },
        "gpu_count": { "type": "integer" },
        "gpu_model": { "type": "string" },
        "total_vram_gb": { "type": "integer" },
        "cpu_cores": { "type": "integer" },
        "ram_gb": { "type": "integer" },
        "status": { "type": "string", "enum": ["healthy", "degraded", "down"] },
        "datacenter": { "type": "string" },
        "rack": { "type": "string" },
        "last_health_check_ts": { "type": "string", "format": "date-time" },
        "_version": { "type": "integer", "default": 1 }
      },
      "required": ["node_id", "hostname", "ip_address", "gpu_count", "gpu_model", "total_vram_gb", "cpu_cores", "ram_gb", "status", "datacenter", "rack", "last_health_check_ts", "_version"]
    },
    "GPUDevice": {
      "primary_key": "device_id",
      "properties": {
        "device_id": { "type": "string" },
        "node_id": { "type": "string" },
        "gpu_index": { "type": "integer" },
        "model": { "type": "string" },
        "vram_gb": { "type": "integer" },
        "driver_version": { "type": "string" },
        "rocm_version": { "type": "string" },
        "temperature_c": { "oneOf": [{ "type": "number" }, { "type": "null" }] },
        "utilization_pct": { "oneOf": [{ "type": "number" }, { "type": "null" }] },
        "power_draw_w": { "oneOf": [{ "type": "number" }, { "type": "null" }] },
        "status": { "type": "string", "enum": ["healthy", "degraded", "down"] },
        "_version": { "type": "integer", "default": 1 }
      },
      "required": ["device_id", "node_id", "gpu_index", "model", "vram_gb", "driver_version", "rocm_version", "temperature_c", "utilization_pct", "power_draw_w", "status", "_version"]
    },
    "KubernetesCluster": {
      "primary_key": "cluster_id",
      "properties": {
        "cluster_id": { "type": "string" },
        "name": { "type": "string" },
        "api_server_url": { "type": "string" },
        "version": { "type": "string" },
        "node_count": { "type": "integer" },
        "gpu_node_count": { "type": "integer" },
        "status": { "type": "string", "enum": ["healthy", "degraded", "unreachable"] },
        "created_at": { "type": "string", "format": "date-time" },
        "_version": { "type": "integer", "default": 1 }
      },
      "required": ["cluster_id", "name", "api_server_url", "version", "node_count", "gpu_node_count", "status", "created_at", "_version"]
    },
    "KubernetesNamespace": {
      "primary_key": "namespace_id",
      "properties": {
        "namespace_id": { "type": "string" },
        "cluster_id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Terminating"] },
        "labels": { "oneOf": [{ "type": "object", "additionalProperties": { "type": "string" } }, { "type": "null" }] },
        "resource_quota": { "oneOf": [{ "type": "object" }, { "type": "null" }] },
        "created_at": { "type": "string", "format": "date-time" },
        "_version": { "type": "integer", "default": 1 }
      },
      "required": ["namespace_id", "cluster_id", "name", "status", "labels", "resource_quota", "created_at", "_version"]
    },
    "KubernetesPod": {
      "primary_key": "pod_id",
      "properties": {
        "pod_id": { "type": "string" },
        "namespace_id": { "type": "string" },
        "node_id": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "name": { "type": "string" },
        "phase": { "type": "string", "enum": ["Pending", "Running", "Succeeded", "Failed", "Unknown"] },
        "restart_count": { "type": "integer", "default": 0 },
        "gpu_requested": { "oneOf": [{ "type": "integer" }, { "type": "null" }] },
        "labels": { "oneOf": [{ "type": "object", "additionalProperties": { "type": "string" } }, { "type": "null" }] },
        "created_at": { "type": "string", "format": "date-time" },
        "started_at": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
        "_version": { "type": "integer", "default": 1 }
      },
      "required": ["pod_id", "namespace_id", "node_id", "name", "phase", "restart_count", "gpu_requested", "labels", "created_at", "started_at", "_version"]
    },
    "ModelVersion": {
      "primary_key": "model_id",
      "properties": {
        "model_id": { "type": "string" },
        "version": { "type": "string" },
        "base_architecture": { "type": "string" },
        "parameter_count": { "type": "integer" },
        "training_dataset_rid": { "type": "string" },
        "training_run_id": { "type": "string" },
        "wandb_url": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "eval_scores": { "oneOf": [{ "type": "object", "additionalProperties": { "type": "number" } }, { "type": "null" }] },
        "status": { "type": "string", "enum": ["training", "staging", "production", "archived"] },
        "created_by": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "promoted_at": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
        "_version": { "type": "integer", "default": 1 }
      },
      "required": ["model_id", "version", "base_architecture", "parameter_count", "training_dataset_rid", "training_run_id", "wandb_url", "eval_scores", "status", "created_by", "created_at", "promoted_at", "_version"]
    },
    "TrainingRun": {
      "primary_key": "run_id",
      "properties": {
        "run_id": { "type": "string" },
        "model_id": { "type": "string" },
        "start_time": { "type": "string", "format": "date-time" },
        "end_time": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
        "status": { "type": "string", "enum": ["running", "completed", "failed", "cancelled"] },
        "num_gpus": { "type": "integer" },
        "total_tokens_trained": { "oneOf": [{ "type": "integer" }, { "type": "null" }] },
        "final_loss": { "oneOf": [{ "type": "number" }, { "type": "null" }] },
        "checkpoint_path": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "config_json": { "type": "string" },
        "_version": { "type": "integer", "default": 1 }
      },
      "required": ["run_id", "model_id", "start_time", "end_time", "status", "num_gpus", "total_tokens_trained", "final_loss", "checkpoint_path", "config_json", "_version"]
    },
    "EvaluationResult": {
      "primary_key": "eval_id",
      "properties": {
        "eval_id": { "type": "string" },
        "model_id": { "type": "string" },
        "benchmark_name": { "type": "string" },
        "score": { "type": "number" },
        "evaluated_at": { "type": "string", "format": "date-time" },
        "evaluator_version": { "type": "string" },
        "breakdown_json": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "_version": { "type": "integer", "default": 1 }
      },
      "required": ["eval_id", "model_id", "benchmark_name", "score", "evaluated_at", "evaluator_version", "breakdown_json", "_version"]
    },
    "Alert": {
      "primary_key": "alert_id",
      "properties": {
        "alert_id": { "type": "string" },
        "title": { "type": "string" },
        "severity": { "type": "string", "enum": ["P1", "P2", "P3", "P4"] },
        "status": { "type": "string", "enum": ["open", "ack", "resolved"] },
        "source_system": { "type": "string" },
        "triggered_at": { "type": "string", "format": "date-time" },
        "acknowledged_at": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
        "resolved_at": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
        "raw_payload_json": { "type": "string" },
        "assigned_to": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "_version": { "type": "integer", "default": 1 }
      },
      "required": ["alert_id", "title", "severity", "status", "source_system", "triggered_at", "acknowledged_at", "resolved_at", "raw_payload_json", "assigned_to", "_version"]
    },
    "Incident": {
      "primary_key": "incident_id",
      "properties": {
        "incident_id": { "type": "string" },
        "title": { "type": "string" },
        "severity": { "type": "string", "enum": ["P1", "P2", "P3", "P4"] },
        "status": { "type": "string", "enum": ["open", "investigating", "resolved"] },
        "root_cause": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "affected_systems": { "type": "array", "items": { "type": "string" } },
        "timeline_json": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "postmortem_rid": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "_version": { "type": "integer", "default": 1 }
      },
      "required": ["incident_id", "title", "severity", "status", "root_cause", "affected_systems", "timeline_json", "postmortem_rid", "_version"]
    },
    "DataPipeline": {
      "primary_key": "pipeline_id",
      "properties": {
        "pipeline_id": { "type": "string" },
        "name": { "type": "string" },
        "owner": { "type": "string" },
        "schedule": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "paused", "failed"] },
        "last_run_ts": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
        "last_run_status": { "oneOf": [{ "type": "string", "enum": ["success", "failure", "running"] }, { "type": "null" }] },
        "output_dataset_rid": { "type": "string" },
        "_version": { "type": "integer", "default": 1 }
      },
      "required": ["pipeline_id", "name", "owner", "schedule", "status", "last_run_ts", "last_run_status", "output_dataset_rid", "_version"]
    },
    "Dataset": {
      "primary_key": "dataset_rid",
      "properties": {
        "dataset_rid": { "type": "string" },
        "name": { "type": "string" },
        "description": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "schema_json": { "type": "string" },
        "row_count": { "oneOf": [{ "type": "integer" }, { "type": "null" }] },
        "size_bytes": { "oneOf": [{ "type": "integer" }, { "type": "null" }] },
        "created_at": { "type": "string", "format": "date-time" },
        "last_updated_at": { "type": "string", "format": "date-time" },
        "data_classification": { "type": "string", "enum": ["public", "internal", "confidential", "restricted"] },
        "_version": { "type": "integer", "default": 1 }
      },
      "required": ["dataset_rid", "name", "description", "schema_json", "row_count", "size_bytes", "created_at", "last_updated_at", "data_classification", "_version"]
    },
    "DataQualityReport": {
      "primary_key": "report_id",
      "properties": {
        "report_id": { "type": "string" },
        "dataset_rid": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "completeness_score": { "type": "number" },
        "uniqueness_score": { "type": "number" },
        "validity_score": { "type": "number" },
        "anomaly_count": { "type": "integer" },
        "issues_json": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "_version": { "type": "integer", "default": 1 }
      },
      "required": ["report_id", "dataset_rid", "generated_at", "completeness_score", "uniqueness_score", "validity_score", "anomaly_count", "issues_json", "_version"]
    }
  }
}
